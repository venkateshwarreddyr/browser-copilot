LLM_BASE_URL=https://router.huggingface.co/v1
HF_API_KEY=
HUGGING_FACE_TOKEN=
LLM_API_KEY=
LLM_MODEL=grok-3

# Security
API_SECRET=                           # Required in prod. Clients must send X-API-Key header.
ALLOWED_ORIGINS=chrome-extension://*  # Comma-separated. Leave empty to allow all origins.
MAX_BODY_BYTES=1048576                # 1 MB default
RATE_LIMIT_WINDOW_MS=60000            # 1 minute window (local server only)
RATE_LIMIT_MAX=30                     # Max requests per window per IP (local server only)
